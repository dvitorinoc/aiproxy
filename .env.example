# AI Proxy — variáveis de ambiente
# Copie para .env e ajuste para o seu ambiente

# Porta HTTP do proxy
AI_PROXY_PORT=9090

# Diretórios de binários adicionados ao PATH para invocar CLIs de IA
AI_PROXY_NVM_NODE=/home/<user>/.nvm/versions/node/<version>/bin
AI_PROXY_LOCAL_BIN=/home/<user>/.local/bin

# Timeouts de execução por provider (ms)
AI_PROXY_TIMEOUT_CLAUDE=180000
AI_PROXY_TIMEOUT_GEMINI=180000
AI_PROXY_TIMEOUT_CODEX=240000

# Webhook — notifica a aplicação sobre eventos da fila
# Eventos: job.started | job.completed | job.failed
AI_PROXY_WEBHOOK_URL=
AI_PROXY_WEBHOOK_SECRET=

# Fila de execução (daemon separado)
AI_PROXY_QUEUE_PORT=9091
AI_PROXY_QUEUE_MAX_CONCURRENT=3
AI_PROXY_QUEUE_MAX_SIZE=50
AI_PROXY_QUEUE_JOB_TIMEOUT=300000
AI_PROXY_QUEUE_POLL_MS=1000
AI_PROXY_QUEUE_DB_PATH=./queue.db
AI_PROXY_QUEUE_CLEANUP_AFTER=86400000

# Loop de ferramentas MCP
AI_PROXY_MCP_MAX_ITERATIONS=6
